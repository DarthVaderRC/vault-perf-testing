      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 35
      },
      "id": 13,
      "targets": [
        {
          "expr": "100 * (1 - avg(node_filesystem_avail_bytes{job=~\"k6.*\",env=~\"$env\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{job=~\"k6.*\",env=~\"$env\",fstype!~\"tmpfs|overlay\"}))",
          "legendFormat": "injector disk used %",
          "refId": "A"
        }
      ],
      "title": "Load Injector Disk Utilization",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 35
      },
      "id": 12,
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total{job=~\"k6.*\",env=~\"$env\"}[5m]))",
          "legendFormat": "injector rx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_transmit_bytes_total{job=~\"k6.*\",env=~\"$env\"}[5m]))",
          "legendFormat": "injector tx",
          "refId": "B"
        }
      ],
      "title": "Load Injector Network I/O",
      "type": "timeseries"
