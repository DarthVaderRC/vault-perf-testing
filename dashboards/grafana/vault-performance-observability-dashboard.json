      "id": 10,
      "targets": [
        {
          "expr": "100 * avg(rate(process_cpu_seconds_total{job=\"k6-injector\",env=~\"$env\"}[5m]))",
          "legendFormat": "injector CPU",
          "refId": "A"
        }
