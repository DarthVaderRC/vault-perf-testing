    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 35
      },
      "id": 11,
      "targets": [
        {
          "expr": "sum(process_resident_memory_bytes{job=\"k6-injector\",env=~\"$env\"})",
          "legendFormat": "injector RSS",
          "refId": "A"
        }
      ],
      "title": "Load Injector Memory",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
